<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Windowless/instant start: use a transparent window background so the
        OS compositor shows the previous screen rather than a white flash while
        Compose is inflating.
    -->
    <style name="Theme.FamilyVoiceReminders" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
